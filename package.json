{
    "name": "inventory-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write 'src/**/*.ts'",
        "test": "jest --forceExit --detectOpenHandles",
        "test:unit": "jest --forceExit --detectOpenHandles --testPathPattern='unit'",
        "test:integration": "jest --forceExit --detectOpenHandles --testPathPattern='integration'",
        "test:coverage": "jest --forceExit --detectOpenHandles --coverage",
        "migration:run": "ts-node src/database/data-source.ts",
        "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
        "seed": "ts-node src/database/seeds/seed.ts"
    },
    "dependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.11.5",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/uuid": "^9.0.7",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "pg": "^8.11.3",
        "reflect-metadata": "^0.2.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "typeorm": "^0.3.19",
        "uuid": "^9.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/jest": "^29.5.11",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^29.7.0",
        "prettier": "^3.2.4",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
